# === Workdocker - Environment Variables ===
# Copy this file to .env.local and fill in the values.

# JWT secret used to sign auth cookies (min 32 chars).
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# PostgreSQL database
# Local development example:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ctv_management
# Nile alternatives:
# DATABASE_POSTGRES_URL=postgres://user:password@host/database
# DATABASE_NILEDB_POSTGRES_URL=postgres://host/database
# DATABASE_NILEDB_USER=
# DATABASE_NILEDB_PASSWORD=
# Optional when your provider requires SSL and the URL does not already include sslmode=require.
DATABASE_SSL=
# Optional. Set to `skip` in stable production environments to avoid runtime schema bootstrap queries.
# Leave empty for local development, CI, or new environments that still rely on runtime bootstrap.
DATABASE_BOOTSTRAP_MODE=

# App origin used for same-origin request validation on cookie-authenticated POST/PUT/DELETE routes.
APP_ORIGIN=http://localhost:3000
# Optional comma-separated list when you need both custom domain and preview/vercel.app domains to work.
APP_ORIGINS=

# Optional Google Sheets source used by the article sync feature.
GOOGLE_SHEETS_ARTICLE_SOURCE_URL=

# Optional override secret used by the Google Apps Script webhook endpoint.
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Optional Apps Script web app URL used for syncing changes from this tool back to Google Sheets.
GOOGLE_SHEETS_SCRIPT_WEB_APP_URL=
# Optional shared secret sent to the Apps Script web app.
# If left empty, the app will reuse GOOGLE_SHEETS_WEBHOOK_SECRET.
GOOGLE_SHEETS_SCRIPT_SECRET=

# Optional demo admin used by seed scripts and CI.
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=change-me-before-deploy

# App Config
NEXT_PUBLIC_APP_NAME=Workdocker
